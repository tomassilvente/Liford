generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum Currency {
  ARS
  USD
}

enum TransactionType {
  EXPENSE
  INCOME
  STOCK_PURCHASE
  CRYPTO_PURCHASE
}

enum TransactionSource {
  PERSONAL
  PHOTOGRAPHY
}

enum InvestmentType {
  STOCK
  CRYPTO
}

enum SessionType {
  SPORT
  EVENT
  OTHER
}

enum SessionStatus {
  PENDING      // coordinando con el cliente
  CONFIRMED    // sesión confirmada
  SHOT         // sesión realizada, editando fotos
  DELIVERED    // fotos entregadas
  PAID         // pago recibido
  COMPLETED    // todo finalizado
}

// ─── USUARIOS ────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  username             String    @unique
  passwordHash         String
  displayName          String?
  onboardingCompleted  Boolean   @default(false)
  createdAt            DateTime  @default(now())

  wallets            Wallet[]
  foreignAccounts    ForeignAccount[]
  investments        Investment[]
  transactions       Transaction[]
  clients            Client[]
  budgets            Budget[]
  recurringExpenses  RecurringExpense[]
  savingsGoals       SavingsGoal[]
  wealthSnapshots    WealthSnapshot[]
  categories         Category[]
}

// Transacciones automáticas mensuales (gastos e ingresos recurrentes)
model RecurringExpense {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  transactionType  TransactionType   @default(EXPENSE)
  description      String
  amount           Float
  currency         Currency          @default(ARS)
  category         String
  source           TransactionSource @default(PERSONAL)
  dayOfMonth       Int               // día del mes en que se aplica (1-28)
  isActive         Boolean           @default(true)
  lastApplied      DateTime?         // último mes en que se creó la transacción
  // cuenta opcional de la que se descuenta el saldo
  walletId         String?
  wallet           Wallet?         @relation(fields: [walletId], references: [id])
  foreignAccountId String?
  foreignAccount   ForeignAccount? @relation(fields: [foreignAccountId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  transactions     Transaction[]   @relation("TransactionRule")
}

// Presupuesto mensual por categoría
model Budget {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  category     String
  monthlyLimit Float
  currency     Currency @default(ARS)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, category, currency])
}

// Metas de ahorro
model SavingsGoal {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  name             String
  targetAmount     Float
  currency         Currency        @default(USD)
  notes            String?
  targetDate       DateTime?
  isAchieved       Boolean         @default(false)
  monthlyDeposit             Float?          // aporte mensual manual estimado
  autoContributionAmount     Float?          // monto del aporte automático
  autoContributionDay        Int?            // día del mes (1-28)
  autoContributionFromWallet String?         // "wallet:id" o "foreign:id"
  walletId         String?
  wallet           Wallet?         @relation(fields: [walletId], references: [id])
  foreignAccountId String?
  foreignAccount   ForeignAccount? @relation(fields: [foreignAccountId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

// Categorías personalizadas del usuario
model Category {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  name      String
  icon      String?    // emoji
  color     String?    // hex color, ej: "#3b82f6"
  type      String     @default("EXPENSE") // EXPENSE | INCOME | BOTH
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, name])
}

// Snapshot mensual de patrimonio
model WealthSnapshot {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  date         DateTime // primer día del mes al que corresponde
  walletsARS   Float
  foreignUSD   Float
  portfolioUSD Float
  totalARS     Float    // suma de billeteras ARS
  totalUSD     Float    // foreignUSD + portfolioUSD
  createdAt    DateTime @default(now())

  @@unique([userId, date])
}

// ─── FINANZAS ────────────────────────────────────────────────────────────────

// Billeteras virtuales (Mercado Pago, Ualá, etc.)
model Wallet {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  name              String
  currency          Currency
  balance           Float              @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  recurringExpenses RecurringExpense[]
  savingsGoals      SavingsGoal[]
}

// Cuentas foráneas (Wise, Payoneer, etc.)
model ForeignAccount {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  name              String
  currency          Currency
  balance           Float              @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  recurringExpenses RecurringExpense[]
  savingsGoals      SavingsGoal[]
}

// Portfolio de inversiones (acciones y crypto)
model Investment {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  ticker      String
  name        String?
  type        InvestmentType
  quantity    Float
  avgBuyPrice Float          // precio promedio de compra en USD
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// Movimientos: gastos, ingresos, compras de activos
model Transaction {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  type        TransactionType
  amount      Float
  currency    Currency
  category    String
  description String?
  source      TransactionSource // PERSONAL o PHOTOGRAPHY
  date        DateTime
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  sessionId          String?
  session            Session?          @relation(fields: [sessionId], references: [id])

  recurrentRuleId    String?
  recurrentRule      RecurringExpense? @relation("TransactionRule", fields: [recurrentRuleId], references: [id])

  attachmentUrl      String?
}

// ─── FOTOGRAFÍA ──────────────────────────────────────────────────────────────

model Client {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  name      String
  instagram String?
  phone     String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
}

model Session {
  id                String        @id @default(cuid())
  clientId          String
  client            Client        @relation(fields: [clientId], references: [id])
  type              SessionType
  eventName         String?
  date              DateTime
  durationMinutes   Int?
  price             Float
  currency          Currency
  photosDelivered   Int?
  status            SessionStatus @default(PENDING)

  googleCalendarId  String?
  driveUrl          String?
  instagramThreadId String?

  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  transactions      Transaction[]
}
